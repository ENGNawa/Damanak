@model IEnumerable<Damanak.Models.Guarantee>

@{
    ViewData["Title"] = "ضماناتي";
}

<section class="py-5">
    <div class="container">

        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
            <div>
                <h2 class="section-title mb-1">ضماناتي</h2>
                <p class="section-subtitle mb-0">
                    اجمعي ضمانات مشترياتك وفواتيرك في مكان واحد.
                </p>
            </div>

            <a asp-action="Create" class="btn btn-primary-custom">
                إضافة ضمان جديد
            </a>
        </div>

        <div class="row g-4 mb-4">

            <div class="col-md-3">
                <div class="stats-card">
                    <div class="stats-label">إجمالي الضمانات</div>
                    <div class="stats-number">@ViewBag.TotalGuarantees</div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="stats-card">
                    <div class="stats-label">سارية</div>
                    <div class="stats-number">@ViewBag.ActiveGuarantees</div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="stats-card">
                    <div class="stats-label">تنتهي قريبًا</div>
                    <div class="stats-number">@ViewBag.ExpiringSoonGuarantees</div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="stats-card">
                    <div class="stats-label">منتهية</div>
                    <div class="stats-number">@ViewBag.ExpiredGuarantees</div>
                </div>
            </div>

        </div>

        <div class="custom-card mb-4">

            <form asp-action="Index" method="get">
                <div class="row g-3 align-items-end">

                    <div class="col-md-5">
                        <label class="form-label">بحث</label>
                        <input type="text" name="searchTerm" class="form-control" value="@ViewBag.SearchTerm"
                               placeholder="اسم المنتج، المتجر، الماركة، أو الرقم التسلسلي" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">الحالة</label>
                        <select name="status" class="form-select">
                            <option value="">كل الحالات</option>

                            @if (ViewBag.Status == "Active")
                            {
                                <option value="Active" selected>ساري</option>
                            }
                            else
                            {
                                <option value="Active">ساري</option>
                            }

                            @if (ViewBag.Status == "ExpiringSoon")
                            {
                                <option value="ExpiringSoon" selected>ينتهي قريبًا</option>
                            }
                            else
                            {
                                <option value="ExpiringSoon">ينتهي قريبًا</option>
                            }

                            @if (ViewBag.Status == "Expired")
                            {
                                <option value="Expired" selected>منتهي</option>
                            }
                            else
                            {
                                <option value="Expired">منتهي</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">التصنيف</label>
                        <select name="category" class="form-select">
                            <option value="">كل التصنيفات</option>

                            @{
                                var categories = new[] { "جوالات", "أجهزة منزلية", "إلكترونيات", "مطبخ", "أثاث", "أخرى" };
                            }

                            @foreach (var cat in categories)
                            {
                                if (ViewBag.Category == cat)
                                {
                                    <option value="@cat" selected>@cat</option>
                                }
                                else
                                {
                                    <option value="@cat">@cat</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="col-md-1 d-grid">
                        <button type="submit" class="btn btn-secondary-custom">
                            بحث
                        </button>
                    </div>

                </div>

                <div class="mt-3">
                    <a asp-action="Index" class="btn btn-outline-custom">
                        إعادة تعيين
                    </a>
                </div>
            </form>

        </div>

        <div class="custom-card">

            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <h4 class="section-title">لا توجد ضمانات</h4>
                    <p class="section-subtitle">
                        ابدئي بإضافة أول ضمان لمنتج اشتريتيه.
                    </p>

                    <a asp-action="Create" class="btn btn-primary-custom">
                        إضافة ضمان
                    </a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>المنتج</th>
                                <th>المتجر</th>
                                <th>التصنيف</th>
                                <th>السعر</th>
                                <th>انتهاء الضمان</th>
                                <th>الحالة</th>
                                <th>الفاتورة</th>
                                <th>الإجراءات</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-bold text-primary-custom">@item.ProductName</div>
                                        <small class="text-muted">@item.Brand @item.ModelName</small>
                                    </td>

                                    <td>@item.StoreName</td>

                                    <td>@item.Category</td>

                                    <td>@item.Price.ToString("N2") ريال</td>

                                    <td>@item.WarrantyEndDate.ToString("yyyy/MM/dd")</td>

                                    <td>
                                        @if (item.Status == "Active")
                                        {
                                            <span class="badge-active">ساري</span>
                                        }
                                        else if (item.Status == "ExpiringSoon")
                                        {
                                            <span class="badge-pending">ينتهي قريبًا</span>
                                        }
                                        else
                                        {
                                            <span class="badge-expired">منتهي</span>
                                        }
                                    </td>

                                    <td>
                                        @if (!string.IsNullOrEmpty(item.InvoiceImagePath))
                                        {
                                            <a href="@item.InvoiceImagePath" target="_blank" class="btn btn-sm btn-outline-custom">
                                                عرض
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">لا يوجد</span>
                                        }
                                    </td>

                                    <td>
                                        <div class="d-flex gap-2 flex-wrap">
                                            <a asp-action="Details" asp-route-id="@item.Id"
                                               class="btn btn-sm btn-outline-custom">
                                                التفاصيل
                                            </a>

                                            <a asp-action="Edit" asp-route-id="@item.Id"
                                               class="btn btn-sm btn-secondary-custom">
                                                تعديل
                                            </a>

                                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                                                حذف
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>

                    </table>
                </div>
            }

        </div>

    </div>
</section>